# Server
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
APP_BASE_URL=http://localhost:3000

# Database (used by Prisma — schema owned by agent-1.1)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexusboard

# JWT
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret

# OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Where the SPA receives the OAuth callback tokens
OAUTH_SUCCESS_REDIRECT=http://localhost:5173/oauth/callback
